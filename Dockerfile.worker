# syntax=docker/dockerfile:1.7

# Build the SWAMP server binary used by worker and sidecar modes.
FROM golang:1.26-alpine AS go-builder
WORKDIR /build

COPY go.mod go.sum ./
RUN go mod download

COPY cmd/ cmd/
COPY internal/ internal/

RUN CGO_ENABLED=0 GOOS=linux go build -o /swamp-server ./cmd/server

# Runtime image for Kubernetes analysis jobs.
# This image must run:
# - SWAMP worker mode (SWAMP_WORKER_MODE=true)
# - SWAMP LLM proxy sidecar mode (SWAMP_LLM_PROXY_MODE=true)
# - External agent binaries (claude / opencode)
FROM alpine:3.21

RUN apk add --no-cache \
    bash \
    ca-certificates \
    git \
    nodejs \
    npm \
    python3 \
  && npm install -g @anthropic-ai/claude-code opencode-ai \
  && npm cache clean --force

COPY --from=go-builder /swamp-server /usr/local/bin/swamp-server

# Match Kubernetes Job expectations from buildJobSpec.
WORKDIR /work

ENV APP_ENV=production

ENTRYPOINT ["/usr/local/bin/swamp-server"]